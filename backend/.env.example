# ── LLM ───────────────────────────────────────────────────────────────────────
# Get free key at: aistudio.google.com → Get API Key → Create API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Model options: gemini-2.0-flash | gemini-1.5-flash | gemini-2.0-flash-lite
LLM_MODEL=gemini-2.0-flash

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
# Optional: enables full JWT signature verification.
# Get from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── Rate Limiting (Upstash Redis) ──────────────────────────────────────────────
# Optional — rate limiting is skipped if blank
UPSTASH_REDIS_URL=https://your-instance.upstash.io

# ── Observability (Langfuse) ───────────────────────────────────────────────────
# Optional — tracing is skipped if blank
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Shopify ────────────────────────────────────────────────────────────────────
# Domain: no https:// prefix e.g. your-store.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_API_VERSION=2024-01
ENABLE_SHOPIFY_CONNECTOR=true

# ── Meta Ads ───────────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=act_your_account_id
META_API_VERSION=v19.0
ENABLE_META_ADS_CONNECTOR=true

# ── Shiprocket ─────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_password
ENABLE_SHIPROCKET_CONNECTOR=true

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DEBUG=true

# ── Scheduler ──────────────────────────────────────────────────────────────────
CONNECTOR_SYNC_INTERVAL_MINUTES=15
WATCHDOG_INTERVAL_HOURS=6
KEEP_WARM_INTERVAL_MINUTES=14
DEFAULT_SYNC_LOOKBACK_DAYS=30
